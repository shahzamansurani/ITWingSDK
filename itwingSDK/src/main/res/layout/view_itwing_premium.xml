<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/itwing_premium_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/itwing_premium_icon_bg"
            android:contentDescription="@string/premium_title"
            android:padding="10dp"
            android:src="@drawable/itwing_ic_premium" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/itwing_premium_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/premium_title"
                android:textColor="#0F172A"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/itwing_premium_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/premium_description"
                android:textColor="#64748B"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/itwing_premium_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/itwing_premium_badge_bg"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="5dp"
            android:text="@string/premium_status_available"
            android:textColor="#2563EB"
            android:textSize="10sp"
            android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/itwing_premium_details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/itwing_purchase_card_bg"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/itwing_premium_plan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#0F172A"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/itwing_premium_billing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:textColor="#475569"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/itwing_premium_price"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textColor="#475569"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/itwing_premium_expiry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textColor="#475569"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/itwing_premium_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="#64748B"
        android:textSize="12sp"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/itwing_premium_progress"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/itwing_premium_purchase"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:text="@string/premium_purchase"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        app:cornerRadius="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/itwing_premium_restore"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:text="@string/premium_restore"
        android:textAllCaps="false"
        android:textSize="14dp"
        app:cornerRadius="12dp"
        app:strokeWidth="1dp" />
</LinearLayout>
