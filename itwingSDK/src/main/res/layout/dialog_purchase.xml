<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/itwing_purchase_scroll"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/itwing_purchase_dialog_bg"
    android:fillViewport="false">

    <LinearLayout
        android:id="@+id/itwing_purchase_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:id="@+id/itwing_purchase_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/itwing_purchase_card_bg"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:text="Premium"
            android:textAllCaps="false"
            android:textColor="#475569"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/itwing_purchase_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="Upgrade your app"
            android:textColor="#0F172A"
            android:textSize="21sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/itwing_purchase_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="6dp"
            android:paddingBottom="16dp"
            android:text="Plans and prices are loaded from Google Play and controlled from ITWing admin."
            android:textColor="#475569"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/itwing_purchase_products"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/itwing_purchase_restore"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="2dp"
            android:text="Restore purchases"
            android:textAllCaps="false"
            android:textColor="#2563EB"
            app:cornerRadius="14dp"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/itwing_purchase_cancel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="4dp"
            android:text="Not now"
            android:textAllCaps="false"
            android:textColor="#64748B"
            app:cornerRadius="14dp" />

    </LinearLayout>
</ScrollView>
