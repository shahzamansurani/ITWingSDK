<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/itwing_purchase_product_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/itwing_purchase_card_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/itwing_purchase_product_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#0F172A"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/itwing_purchase_product_price"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:textColor="#2563EB"
        android:textSize="23sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/itwing_purchase_product_offer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:textColor="#16A34A"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/itwing_purchase_product_period"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="2dp"
        android:paddingBottom="8dp"
        android:textColor="#64748B"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/itwing_purchase_product_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lineSpacingMultiplier="1.08"
        android:paddingBottom="12dp"
        android:textColor="#475569"
        android:textSize="12sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/itwing_purchase_product_button"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center"
        android:minHeight="48dp"
        android:text="Continue"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        app:cornerRadius="14dp" />
</LinearLayout>
