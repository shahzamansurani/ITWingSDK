<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/itwing_flow_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/itwing_flow_splash_bg_ref">

    <ImageView
        android:id="@+id/itwing_flow_splash_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:adjustViewBounds="false"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/itwing_flow_splash_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_margin="@dimen/_20sdp"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/itwing_flow_splash_logo"
            android:layout_width="@dimen/_40sdp"
            android:layout_height="@dimen/_40sdp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/itwing_flow_app_logo"
            android:scaleType="fitCenter"
            android:src="@drawable/itwing_flow_splash_logo" />

        <TextView
            android:id="@+id/itwing_flow_splash_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20sdp"
            android:fontFamily="@font/itwing_flow_proxima_nova"
            android:gravity="center"
            android:text="@string/app_name"
            android:textColor="@android:color/white"
            android:textSize="@dimen/_22ssp" />

        <TextView
            android:id="@+id/itwing_flow_splash_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:fontFamily="@font/itwing_flow_proxima_nova"
            android:gravity="center"
            android:text="@string/splash_desc"
            android:textColor="@android:color/white"
            android:textSize="@dimen/_13ssp" />

    </LinearLayout>

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/itwing_flow_splash_lottie"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/_80sdp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_gravity="bottom"
        android:adjustViewBounds="true"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/itwing_flow_anim_loading" />

</RelativeLayout>
